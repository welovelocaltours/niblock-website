{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": false,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "redirects": [
    { "source": "/ecommerce-fulfilment-pick-and-pack", "destination": "/ecommerce-fulfilment.html", "permanent": true },
    { "source": "/ecommerce-fulfilment-pick-and-pack/", "destination": "/ecommerce-fulfilment.html", "permanent": true },
    { "source": "/warehouse-services", "destination": "/ecommerce-fulfilment.html", "permanent": true },
    { "source": "/warehouse-services/", "destination": "/ecommerce-fulfilment.html", "permanent": true },
    { "source": "/commercial-storage", "destination": "/commercial-storage.html", "permanent": true },
    { "source": "/commercial-storage/", "destination": "/commercial-storage.html", "permanent": true },
    { "source": "/transport-distribution", "destination": "/transport-distribution.html", "permanent": true },
    { "source": "/transport-distribution/", "destination": "/transport-distribution.html", "permanent": true },
    { "source": "/next-day-courier", "destination": "/transport-distribution.html", "permanent": true },
    { "source": "/next-day-courier/", "destination": "/transport-distribution.html", "permanent": true },
    { "source": "/international-shipping-consolidation", "destination": "/transport-distribution.html", "permanent": true },
    { "source": "/international-shipping-consolidation/", "destination": "/transport-distribution.html", "permanent": true },
    { "source": "/logistics-contracts", "destination": "/logistics-consultancy.html", "permanent": true },
    { "source": "/logistics-contracts/", "destination": "/logistics-consultancy.html", "permanent": true },
    { "source": "/logistics-management-consultancy", "destination": "/logistics-consultancy.html", "permanent": true },
    { "source": "/logistics-management-consultancy/", "destination": "/logistics-consultancy.html", "permanent": true },
    { "source": "/exhibitions-event-logistics", "destination": "/exhibition-event-logistics.html", "permanent": true },
    { "source": "/exhibitions-event-logistics/", "destination": "/exhibition-event-logistics.html", "permanent": true },
    { "source": "/about", "destination": "/about.html", "permanent": true },
    { "source": "/about/", "destination": "/about.html", "permanent": true },
    { "source": "/testimonials", "destination": "/case-studies.html", "permanent": true },
    { "source": "/testimonials/", "destination": "/case-studies.html", "permanent": true },
    { "source": "/contact-us", "destination": "/contact.html", "permanent": true },
    { "source": "/contact-us/", "destination": "/contact.html", "permanent": true },
    { "source": "/privacy-policy", "destination": "/privacy.html", "permanent": true },
    { "source": "/privacy-policy/", "destination": "/privacy.html", "permanent": true }
  ]
}
